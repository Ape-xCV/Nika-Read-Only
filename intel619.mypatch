+static int handle_cpuid(struct kvm_vcpu *vcpu)  // NIKA begin
+{
+	/*
+	 * Intel® Core™ processors 6th gen: GRUB_CMDLINE_LINUX="mitigations=off"
+	 * Intel® Core™ processors 11th gen: GRUB_CMDLINE_LINUX="mitigations=on"
+	 */
+//	if (vcpu->kvm->intercept_cpuid && rdtsc() - vcpu->kvm->last_exit_start > 290304000000)  // Intel® Core™ processors >120 seconds
+	if (vcpu->kvm->intercept_cpuid && rdtsc() - vcpu->kvm->last_exit_start > 145152000000)  // Intel® Core™ processors >60 seconds
+		vcpu->kvm->intercept_cpuid = false;
+
+	u32 eax, ebx, ecx, edx, in_eax, in_ecx;
+//	if (cpuid_fault_enabled(vcpu) && !kvm_require_cpl(vcpu, 0))
+//		return 1;
+	eax = kvm_rax_read(vcpu);
+	ecx = kvm_rcx_read(vcpu);
+	in_eax = eax;
+	in_ecx = ecx;
+	kvm_cpuid(vcpu, &eax, &ebx, &ecx, &edx, false);
+//	if (in_eax == 0x01) ecx |= 0x80000000;  // Hyper-V fix
+	if (in_eax == 0x07 && in_ecx == 0x00) edx &= 0x73FFFFFF;  // Skylake fix
+	kvm_rax_write(vcpu, eax);
+	kvm_rbx_write(vcpu, ebx);
+	kvm_rcx_write(vcpu, ecx);
+	kvm_rdx_write(vcpu, edx);
+	if (in_eax <= 0x24) {
+		if (((0x00000019E0FDF890ULL >> in_eax) & 1ULL) == 0) in_ecx = 0;
+		else in_ecx = min(in_ecx, 0x3FU);
+			vcpu->kvm->cpuid_cache[in_eax][in_ecx].rdy = 1;
+			vcpu->kvm->cpuid_cache[in_eax][in_ecx].eax = eax;
+			vcpu->kvm->cpuid_cache[in_eax][in_ecx].ebx = ebx;
+			vcpu->kvm->cpuid_cache[in_eax][in_ecx].ecx = ecx;
+			vcpu->kvm->cpuid_cache[in_eax][in_ecx].edx = edx;
+	}
+	else if (in_eax >= 0x80000000 && in_eax <= 0x80000020) {
+		in_eax -= 0x80000000;
+		if (((0x0000000120000000ULL >> in_eax) & 1ULL) == 0) in_ecx = 0;
+		else in_ecx = min(in_ecx, 0x04U);
+			vcpu->kvm->ext_cpuid_cache[in_eax][in_ecx].rdy = 1;
+			vcpu->kvm->ext_cpuid_cache[in_eax][in_ecx].eax = eax;
+			vcpu->kvm->ext_cpuid_cache[in_eax][in_ecx].ebx = ebx;
+			vcpu->kvm->ext_cpuid_cache[in_eax][in_ecx].ecx = ecx;
+			vcpu->kvm->ext_cpuid_cache[in_eax][in_ecx].edx = edx;
+	}
+	return kvm_skip_emulated_instruction(vcpu);
+}  // NIKA end
+
 /*
  * The exit handlers return 1 if the exit was handled fully and guest execution
  * may resume.  Otherwise they set the kvm_run parameter to indicate what needs
@@ -6247,7 +6299,8 @@
