+	else if (vcpu->arch.db[1] == next_rip && (vcpu->arch.dr7 & 0x0C)) kvm_queue_exception_p(vcpu, DB_VECTOR, DR6_BS | DR_TRAP1);  // NIKA added
+	else if (vcpu->arch.db[2] == next_rip && (vcpu->arch.dr7 & 0x30)) kvm_queue_exception_p(vcpu, DB_VECTOR, DR6_BS | DR_TRAP2);  // NIKA added
+	else if (vcpu->arch.db[3] == next_rip && (vcpu->arch.dr7 & 0xC0)) kvm_queue_exception_p(vcpu, DB_VECTOR, DR6_BS | DR_TRAP3);  // NIKA added
